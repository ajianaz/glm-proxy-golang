# =============================================================================
# GLM Proxy - Environment Variables
# =============================================================================
# Copy file ini menjadi .env:  cp .env.example .env
# Lalu isi nilai yang sesuai.
# =============================================================================

# -----------------------------------------------------------------------------
# WAJIB - Z.AI Master API Key
# -----------------------------------------------------------------------------
# Dapatkan dari: https://open.bigmodel.cn/ -> Console -> API Keys
# Ini adalah fallback key untuk semua user yang TIDAK punya glmkey di apikeys.json
ZAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# OPSIONAL - Default Model
# -----------------------------------------------------------------------------
# Model yang digunakan jika user tidak punya field "model" di apikeys.json
# Pilihan: glm-4.7, glm-4.5-air, glm-4.5-flash
DEFAULT_MODEL=glm-4.7

# -----------------------------------------------------------------------------
# OPSIONAL - Server Port
# -----------------------------------------------------------------------------
PORT=3000

# -----------------------------------------------------------------------------
# OPSIONAL - Path ke file API keys
# -----------------------------------------------------------------------------
# Di Docker: gunakan /app/data/apikeys.json (volume mount ke ./data)
# Local:     gunakan data/apikeys.json (relative path)
DATA_FILE=/app/data/apikeys.json

# -----------------------------------------------------------------------------
# OPSIONAL - Domain (Traefik)
# -----------------------------------------------------------------------------
# Domain untuk Traefik reverse proxy + Let's Encrypt TLS.
# Pastikan DNS A record sudah diarahkan ke server ini.
DOMAIN=glm.ajianaz.dev
